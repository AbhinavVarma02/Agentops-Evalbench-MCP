# =====================================================================
# AgentOps EvalBench MCP - Example environment file
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows)
#
# The real `.env` file is git-ignored and must NEVER be committed.
# =====================================================================

# ---- Required ----------------------------------------------------------
# OpenAI API key used for embeddings + chat completions in the RAG pipeline
# and the optional LLM-judge evaluators.
OPENAI_API_KEY=

# PostgreSQL connection string. For the MVP this points at a hosted
# Supabase Postgres instance (Supabase is used ONLY as Postgres).
# Example (Supabase): postgresql+psycopg://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
# Example (local dev): postgresql+psycopg://postgres:postgres@localhost:5432/agentops
# If left blank, the app falls back to a local SQLite file so you can run
# everything without a database server (great for demos / CI).
DATABASE_URL=

# ---- Optional: tracing / observability --------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agentops-evalbench

# ---- Optional: app + service URLs -------------------------------------
APP_ENV=development
API_BASE_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:8501

# ---- Optional: RAG / model configuration ------------------------------
CHROMA_PERSIST_DIR=./data/chroma
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ---- Optional: evaluation thresholds (deployment-readiness gate) ------
EVAL_MIN_GROUNDEDNESS=0.80
EVAL_MAX_HALLUCINATION_RISK=0.20
EVAL_MIN_RETRIEVAL_SCORE=0.75
EVAL_MIN_ANSWER_RELEVANCE=0.70
EVAL_MAX_LATENCY_SECONDS=5
